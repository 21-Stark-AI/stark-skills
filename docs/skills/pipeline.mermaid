graph LR
    subgraph "Design"
        A["/stark-design<br/>3 generate + 6 review"] -->|design doc| B["/stark-review-design<br/>N agents × 10 domains"]
    end
    subgraph "Planning"
        B -->|reviewed design| C["/stark-design-to-plan<br/>3 generate + 6 review"]
        C -->|impl plan| D["/stark-review-plan<br/>N agents × 10 domains"]
        D -->|reviewed plan| E["/stark-plan-to-tasks<br/>3 LLM passes"]
    end
    subgraph "Execution"
        E -->|GitHub issues| F["/stark-phase-execute<br/>autonomous loop"]
        F -->|PRs| G["/stark-review<br/>3 agents × 6 domains"]
    end

    style A fill:#4a9eff,color:#fff,stroke:#2a7de0
    style B fill:#f5a623,color:#fff,stroke:#d48b0f
    style C fill:#4a9eff,color:#fff,stroke:#2a7de0
    style D fill:#f5a623,color:#fff,stroke:#d48b0f
    style E fill:#7b68ee,color:#fff,stroke:#5a47cd
    style F fill:#50c878,color:#fff,stroke:#30a858
    style G fill:#f5a623,color:#fff,stroke:#d48b0f
