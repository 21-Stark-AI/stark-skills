graph TB
    subgraph "Pipeline: Idea → Production"
        direction LR
        D["/stark-design"] --> RD["/stark-review-design"]
        RD --> D2P["/stark-design-to-plan"]
        D2P --> RP["/stark-review-plan"]
        RP --> P2T["/stark-plan-to-tasks"]
        P2T --> PE["/stark-phase-execute"]
        PE --> R["/stark-review"]
    end

    subgraph "Workflow"
        PF["/stark-pr-flow"]
        S["/stark-session"]
        REL["/stark-release"]
        T["/stark-tournament"]
    end

    subgraph "Documentation"
        ID["/stark-init-docs"]
        ED["/stark-extract-docs"]
        GD["/stark-generate-docs"]
        CMI["/stark-claude-md-improver"]
    end

    subgraph "Analytics"
        M["/stark-metrics"]
        PS["/stark-pr-status"]
        SA["/stark-skill-analytics"]
        SI["/stark-session-insights"]
    end

    subgraph "Maintenance"
        UD["/stark-update-deps"]
        RI["/stark-review-improvement"]
        OP["/stark-onboard-project"]
        RN["/stark-rename-project"]
    end

    PE -.->|creates PRs| PF
    R -.->|findings feed| RI
    RI -.->|improves prompts for| R
    S -.->|starts/ends| PE
    PE -.->|after merge| REL

    style D fill:#4a9eff,color:#fff
    style RD fill:#f5a623,color:#fff
    style D2P fill:#4a9eff,color:#fff
    style RP fill:#f5a623,color:#fff
    style P2T fill:#7b68ee,color:#fff
    style PE fill:#50c878,color:#fff
    style R fill:#f5a623,color:#fff
